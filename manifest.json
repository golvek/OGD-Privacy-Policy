{
  "manifest_version": 3,
  "name": "Ogden",
  "version": "2.0",
  "description": "Minimal task and time tracker overlay for raters",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://review.intern.facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://review.intern.facebook.com/intern/review/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
